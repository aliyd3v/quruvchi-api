  descUz    String? @map("desc_uz")
  descRu    String? @map("desc_ru")
  descEn    String? @map("desc_en")
  isVisible Boolean @default(false) @map("is_visible")
  isActive  Boolean @default(true) @map("is_active")

  attachments  Attachment[] @relation("catalog_gallery")
  previewImage Attachment[] @relation("catalog_preview")

  items CatalogItem[]

  direction   CatalogDirection? @relation(fields: [directionId], references: [id], onDelete: SetNull)
  directionId Int?              @map("direction_id")

  createdBy   User? @relation("catalog_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  createdById Int?  @map("created_by_id")
  deletedBy   User? @relation("catalog_deleted_by", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedById Int?  @map("deleted_by_id")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
}

model CatalogItem {
