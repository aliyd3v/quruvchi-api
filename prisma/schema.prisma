generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPERADMIN
  ADMIN
  ACCOUNTANT
  WORKER
  PTO
}

model User {
  id                        Int       @id @default(autoincrement())
  fname                     String?   @db.VarChar(255)
  lname                     String?   @db.VarChar(255)
  phone                     String    @unique @db.VarChar(20)
  email                     String?   @unique @db.VarChar(255)
  password                  String
  permissions               String[]  @default([])
  is2FAEnabled              Boolean   @default(false) @map("is_2fa_enabled")
  twoFASecret               String?   @map("two_fa_secret")
  isActive                  Boolean   @default(true) @map("is_active")
  blockedUntil              DateTime? @map("blocked_until") @db.Timestamptz(6)
  lastSeans                 DateTime? @map("last_seans") @db.Timestamptz(6)
  currentBaseSalary         BigInt    @default(0)
  lastPaidDate              DateTime? @map("last_paid_date") @db.Timestamptz(6)
  currentSalaryMonthEndDate DateTime? @map("salary_month_end_date") @db.Timestamptz(6)
  birthday                  DateTime? @db.Timestamptz(6)

  balance      BigInt @default(0)
  totalIncome  BigInt @default(0) @map("total_income")
  totalExpense BigInt @default(0) @map("total_expense")
  version      Int    @default(0)
  pwdVersion   Int    @default(0) @map("pwd_version")

  role Role

  ResetAuthAttempts ResetAuthAttempts[] @relation("user_reset_auth_attemt")

  avatar Avatar?

  createdTasks Task[] @relation("created_task")
  deletedTasks Task[] @relation("task_deleted_by")

  lots             Lot[]     @relation("lot_assigneds")
  createdLots      Lot[]     @relation("lot_created_by")
  deletedLots      Lot[]     @relation("lot_deleted_by")
  lotTasks         LotTask[]
  completedLotTask LotTask[] @relation("lot_task_completed_by")
  createdLotTask   LotTask[] @relation("lot_task_created_by")

  attachment         Attachment[] @relation("attachment_created_by")
  deletedAttachments Attachment[] @relation("attachment_deleted_by")

  objects        Object[] @relation("assigned_users")
  createdObjects Object[] @relation("object_created_by")
  deletedObjects Object[] @relation("object_deleted_by")

  executedTransactions Transaction[]     @relation("txn_executed_by")
  createdTransactions  Transaction[]     @relation("txn_created_by")
  deletedTransactions  Transaction[]     @relation("txn_deleted_by")
  createdTxnItems      TransactionItem[] @relation("txn_item_created_by")
  deletedTxnItems      TransactionItem[] @relation("txn_item_deleted_by")

  organizationsCreated Organization[] @relation("organization_created_by")
  deletedOrganization  Organization[] @relation("organization_deleted_by")

  workVolumes        WorkVolume[] @relation("work_volume_created_by")
  deletedWorkVolumes WorkVolume[] @relation("work_volume_deleted_by")

  createdDebts           Debt[]            @relation("debt_created_by")
  deletedDebts           Debt[]            @relation("debt_deleted_by")
  createdDebtTxns        DebtTransaction[] @relation("debt_txn_created_by")
  deletedDebtTxns        DebtTransaction[] @relation("debt_txn_deleted_by")
  createdDebtItems       DebtItem[]        @relation("debt_item_created_by")
  deletedDebtItems       DebtItem[]        @relation("debt_item_deleted_by")
  createdDebtPayments    DebtPayment[]     @relation("debt_payment_created_by")
  deletedDebtPayments    DebtPayment[]     @relation("debt_payment_deleted_by")
  performedDebtAuditLogs DebtAuditLog[]    @relation("debt_audit_log_performed_by")

  answerToWorkVolumes        AnswerToWorkVolume[] @relation("answer_to_work_volume_created_by")
  deletedAnswerToWorkVolumes AnswerToWorkVolume[] @relation("answer_to_work_volume_deleted_by")

  salaryMonths        SalaryMonth[] @relation("user_salary_month")
  createdSalaryMonths SalaryMonth[] @relation("salary_month_created_by")
  deletedSalaryMonths SalaryMonth[] @relation("salary_month_deleted_by")

  salaryPayments        SalaryPayment[] @relation("user_salary_payment")
  createdSalaryPayments SalaryPayment[] @relation("salary_payment_created_by")
  deletedSalaryPayments SalaryPayment[] @relation("salary_payment_deleted_by")

  complatedTasks Task[] @relation("task_complated_by")

  tasks TaskAssignment[]

  taskComments        TaskComment[] @relation("task_comment_created_by")
  deletedTaskComments TaskComment[] @relation("task_comment_deleted_by")
  commetnsToUser      TaskComment[] @relation("comments_to_user")

  taskHistories        TaskHistory[] @relation("task_history_created_by")
  deletedTaskHistories TaskHistory[] @relation("task_history_deleted_by")

  acceptedTransfers FundTransfer[] @relation("accepted_user_transfers")
  sendedTransfers   FundTransfer[] @relation("sended_user_transfers")
  createdTransfers  FundTransfer[] @relation("transfer_created_by")
  deletedTransfers  FundTransfer[] @relation("trnasfer_deleted_by")

  createdInventories Inventory[] @relation("inventory_created_by")
  deletedInventories Inventory[] @relation("inventory_deleted_by")

  executedInventoryHistories InventoryHistory[] @relation("inventory_history_executed_by")
  createdInventoryHistories  InventoryHistory[] @relation("inventory_history_created_by")
  deletedInventoryHistories  InventoryHistory[] @relation("inventory_history_deleted_by")

  createdBranches Branch[] @relation("branch_created_by")
  deletedBranches Branch[] @relation("branch_deleted_by")

  createdEntries Entry[] @relation("entry_created_by")
  deletedEntries Entry[] @relation("entry_deleted_by")

  createdCatalogDirections CatalogDirection[] @relation("catalog_direction_created_by")
  deletedCatalogDirections CatalogDirection[] @relation("catalog_direction_deleted_by")
  createdCatalogs          Catalog[]          @relation("catalog_created_by")
  deletedCatalogs          Catalog[]          @relation("catalog_deleted_by")
  createdCatalogItems      CatalogItem[]      @relation("catalog_item_created_by")
  deletedCatalogItems      CatalogItem[]      @relation("catalog_item_deleted_by")
  createdCatalogMaterials  CatalogMaterial[]  @relation("catalog_material_created_by")
  deletedCatalogMaterials  CatalogMaterial[]  @relation("catalog_material_deleted_by")

  callEvents CallEvent[]

  createdUsers User[] @relation("user_created_by")
  deletedUsers User[] @relation("user_deleted_by")

  createdBy   User? @relation("user_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  createdById Int?  @map("created_by_id")
  deletedBy   User? @relation("user_deleted_by", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedById Int?  @map("deleted_by_id")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
}

model ResetAuthAttempts {
  id           Int       @id @default(autoincrement())
  attemptId    String    @unique @default(uuid()) @map("attempt_id") @db.Uuid()
  userId       Int       @map("user_id")
  user         User      @relation("user_reset_auth_attemt", fields: [userId], references: [id])
  ip           String
  userAgent    String    @map("user_agent")
  code         String
  type         String    @db.VarChar(255)
  used         Boolean   @default(false)
  usedForReset Boolean   @default(false) @map("used_for_reset")
  blocked      Boolean   @default(false)
  period       Int       @default(1)
  attemptCount Int       @default(0) @map("attempt_count")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
}

model TempToken {
  id        Int       @id @default(autoincrement())
  jti       String    @unique @default(uuid())
  userId    Int       @map("user_id")
  type      String?
  expiresAt DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
}

model Avatar {
  id        Int      @id @default(autoincrement())
  filename  String   @db.VarChar(255)
  url       String
  size      Int?
  userId    Int      @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
}

model Organization {
  id               Int     @id @default(autoincrement())
  organizationName String  @map("organization_name") @db.VarChar(255)
  stirNumber       String  @map("stir_number") @db.VarChar(255)
  ownerName        String  @map("owner_name") @db.VarChar(255)
  ownerPhone       String? @map("owner_phone") @db.VarChar(20)
  sellerPhone      String? @map("seller_phone") @db.VarChar(20)
  isActive         Boolean @default(true) @map("is_active")

  balance      BigInt @default(0)
  totalExpense BigInt @default(0) @map("total_expense")
  totalIncome  BigInt @default(0) @map("totla_income")
  version      Int    @default(0)

  address    Location? @relation(fields: [locationId], references: [id])
  locationId Int?      @map("location_id")

  status OrganizationStatus @default(NOT_ACTIVE)

  parent   Organization?  @relation("organization_branch", fields: [parentId], references: [id])
  parentId Int?           @map("parent_id")
  branches Organization[] @relation("organization_branch")

  transactions Transaction[]

  transfersFrom FundTransfer[] @relation("to_organization_transfers")
  transfersto   FundTransfer[] @relation("from_organization_transfers")

  debts Debt[]

  entries Entry[]

  inventoryHistories InventoryHistory[]

  tasks Task[]

  taskClient Task[] @relation("task_client_organization")

  createdBy   User? @relation("organization_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  createdById Int?  @map("created_by_id")
  deletedBy   User? @relation("organization_deleted_by", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedById Int?  @map("deleted_by_id")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
}

enum OrganizationStatus {
  ACTIVE
  NOT_ACTIVE
}

model Object {
  id           Int      @id @default(autoincrement())
  name         String
  serviceName  String?  @map("service_name")
  description  String
  startDate    DateTime @map("start_date") @db.Timestamptz(6)
  endDate      DateTime @map("end_date") @db.Timestamptz(6)
  budget       BigInt   @default(0)
  balance      BigInt   @default(0)
  totalIncome  BigInt   @default(0) @map("total_income")
  totalExpense BigInt   @default(0) @map("total_expense")
  version      Int      @default(0)
  isActive     Boolean  @default(true) @map("is_active")

  status ObjectStatus @default(ACTIVE)

  address    Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationId Int?      @map("location_id")

  projectType ProjectType? @map("project_type")
  workType    WorkType?    @default(OTHER) @map("work_type")

  attachments Attachment[]
  tasks       Task[]

  workVolumes WorkVolume[]

  transfersTo   FundTransfer[] @relation("from_object_transfers")
  transfersFrom FundTransfer[] @relation("to_object_transfers")

  transactions Transaction[]

  salaryMonths SalaryMonth[]

  inventoryHistory InventoryHistory[]

  assigned    User[] @relation("assigned_users")
  createdById Int?   @map("created_by_id")
  createdBy   User?  @relation("object_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  deletedById Int?   @map("deleted_by_id")
  deletedBy   User?  @relation("object_deleted_by", fields: [deletedById], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
}

model Location {
  id           Int            @id @default(autoincrement())
  lat          Decimal        @db.Decimal(9, 6)
  lon          Decimal        @db.Decimal(9, 6)
  object       Object[]
  organization Organization[]
}

enum ObjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  LATE
}

enum ProjectType {
  REPAIR
  CONSTRUCTION
  EQUIPMENT
  OTHER
}

enum WorkType {
  CONSTRUCTION
  TRADE
  FURNITURE
  SEWING
  SMETA
  OTHER
}

model WorkVolume {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  quantity    Float
  unitPrice   BigInt  @map("unit_price")
  totalAmount BigInt  @map("total_amount")
  spentAmount BigInt  @default(0) @map("spent_amount")
  version     Int     @default(0)
  isActive    Boolean @default(true) @map("is_active")

  unit Unit

  object   Object? @relation(fields: [objectId], references: [id], onDelete: Cascade)
  objectId Int?    @map("objetc_id")

  createdBy   User? @relation("work_volume_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  createdById Int?  @map("created_by_id")
  deletedBy   User? @relation("work_volume_deleted_by", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedById Int?  @map("deleted_by_id")

  answersToWorkVolume AnswerToWorkVolume[]

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
}

enum Unit {
  M
  M2
  M3
  TON
  KG
  L
  PCS
  H
  DAY
  SET
  UZS
  WORK_VOLUME
  SERVICE
}

enum WorkVolumeStatus {
  OVERRUN
}

model AnswerToWorkVolume {
  id          Int     @id @default(autoincrement())
  quantity    Float
  unitPrice   BigInt  @map("unit_price")
  totalAmount BigInt  @map("total_amount")
  notes       String?
  isActive    Boolean @default(true) @map("is_active")

  unit Unit

  workVolume   WorkVolume @relation(fields: [workVolumeId], references: [id], onDelete: Cascade)
  workVolumeId Int        @map("work_volume_id")

  createdBy   User? @relation("answer_to_work_volume_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  createdById Int?  @map("created_by_id")
  deletedBy   User? @relation("answer_to_work_volume_deleted_by", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedById Int?  @map("deleted_by_id")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
}

model Lot {
  id                         Int       @id @default(autoincrement())
  title                      String
  lotId                      String?   @map("lot_id")
  startingPrice              BigInt?   @map("starting_price")
  guaranteeAmount            BigInt?   @map("guarantee_amount")
  lotEndDate                 DateTime? @map("lot_end_date") @db.Timestamptz(6)
  objectId                   String?   @map("object_id")
  tenderType                 String?   @map("tender_type")
  lotBranch                  String?   @map("lot_branch")
  workExecutionType          String?   @map("work_execution_type")
  objectComplexityCategory   String?   @map("object_complexity_category")
  programCategory            String?   @map("program_category")
  fundingSource              String?   @map("funding_source")
  fundingAmountCurrentYear   BigInt?   @map("funding_amount_current_year")
  workDurationDays           Int?      @map("work_duration_days")
  proposalSubmissionDeadline Int?      @map("proposal_submission_deadline")
  customer                   String?
  objectRegion               String?   @map("object_region")
  objectCityDistrict         String?   @map("object_city_district")
  objectAddress              String?   @map("object_address")
  organizerName              String?   @map("organizer_name")
  contactPerson              String?   @map("contact_person")
  organizationDirector       String?   @map("organization_director")
  organizationPhone          String?   @map("organization_phone")
  organizationEmail          String?   @map("organization_email")
  tenderFiles                String?   @map("tender_files")

  isActive Boolean    @default(true) @map("is_active")
  status   LotStatus? @default(OPEN)

  tasks LotTask[]

  attachments Attachment[]

  assigned    User[] @relation("lot_assigneds")
  createdBy   User?  @relation("lot_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  createdById Int?   @map("created_by_id")
  deletedBy   User?  @relation("lot_deleted_by", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedById Int?   @map("deleted_by_id")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
}

enum LotStatus {
  OPEN
  LATE
  IN_PROCESS
  ENDED
  SUCCESS
}

model LotTask {
  id Int @id @default(autoincrement())

  taskDescription      String  @map("task_description")
  completedDescription String? @map("completed_description")
  isActive             Boolean @default(true) @map("is_active")

  status LotTaskStatus? @default(NOT_STARTED)

  lot   Lot? @relation(fields: [lotId], references: [id], onDelete: Cascade)
  lotId Int? @map("lot_id")

  taskFiles      Attachment[] @relation("lot_task_files")
  complatedFiles Attachment[] @relation("lot_task_complated_files")

  assigned      User[]
  completedBy   User?  @relation("lot_task_completed_by", fields: [completedById], references: [id], onDelete: SetNull)
  completedById Int?
  createdBy     User?  @relation("lot_task_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  createdById   Int?   @map("created_by_id")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
}

enum LotTaskStatus {
  NOT_STARTED
  IN_PROCESS
  CHECKING
  COMPLETED
}

model FundTransfer {
  id             Int     @id @default(autoincrement())
  amount         BigInt
  note           String?
  contractNumber String? @map("contract_number")
  isActive       Boolean @default(true) @map("is_active")

  recipientUser   User? @relation("accepted_user_transfers", fields: [recipientUserId], references: [id], onDelete: SetNull)
  recipientUserId Int?  @map("recipient_user_id")
  senderUser      User? @relation("sended_user_transfers", fields: [senderUserId], references: [id], onDelete: SetNull)
  senderUserId    Int?  @map("sender_user_id")

  fromObject   Object? @relation("from_object_transfers", fields: [fromObjectId], references: [id], onDelete: SetNull)
  fromObjectId Int?    @map("from_object_id")
  toObject     Object? @relation("to_object_transfers", fields: [toObjectId], references: [id], onDelete: SetNull)
  toObjectId   Int?    @map("to_object_id")

  toOrganization     Organization? @relation("to_organization_transfers", fields: [toOrganizationId], references: [id], onDelete: SetNull)
  toOrganizationId   Int?          @map("to_organization_id")
  fromOrganization   Organization? @relation("from_organization_transfers", fields: [fromOrganizationId], references: [id], onDelete: SetNull)
  fromOrganizationId Int?          @map("from_organization_id")

  createdBy   User? @relation("transfer_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  createdById Int?
  deletedBy   User? @relation("trnasfer_deleted_by", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedById Int?  @map("deleted_by_id")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
}

model Transaction {
  id         Int      @id @default(autoincrement())
  notes      String?
  amount     BigInt
  date       DateTime @default(now()) @db.Timestamptz(6)
  purpose    String?
  isReviewed Boolean  @default(false) @map("is_reviewed")
  isSalary   Boolean  @default(false) @map("is_salary")
  isActive   Boolean  @default(true) @map("is_active")

  type TransactionType

  object   Object? @relation(fields: [objectId], references: [id], onDelete: SetNull)
  objectId Int?    @map("object_id")

  attachments Attachment[]

  organization                Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  organizationId              Int?          @map("organization_id")
  usedFromOrganizationBalance Boolean       @default(false) @map("used_from_organization_balance")

  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  branchId Int?    @map("branch_id")

  salaryPayment SalaryPayment? @relation("salary_payment_transaction")

  items TransactionItem[]

  executedBy   User? @relation("txn_executed_by", fields: [executedById], references: [id], onDelete: SetNull)
  executedById Int?  @map("executed_by_id")
  createdBy    User? @relation("txn_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  createdById  Int?  @map("created_by_id")
  deletedBy    User? @relation("txn_deleted_by", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedById  Int?  @map("deleted_by_id")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
}

model TransactionItem {
  id           Int      @id @default(autoincrement())
  name         String?
  parameter    String?
  quantity     Decimal? @db.Decimal(18, 3)
  pricePerUnit BigInt?  @map("price_per_unit")
  totalPrice   BigInt?
  isActive     Boolean  @default(true) @map("is_active")

  unit Unit?

  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId Int?         @map("transaction_id")

  inventoryHistory InventoryHistory? @relation("TransactionItemHistory")

  createdBy   User? @relation("txn_item_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  createdById Int?
  deletedBy   User? @relation("txn_item_deleted_by", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedById Int?

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Attachment {
  id           Int     @id @default(autoincrement())
  originalname String?
  filename     String?
  mimeType     String?
  filesize     Int?
  url          String
  checksum     String?
  isActive     Boolean @default(true) @map("is_active")

  object   Object? @relation(fields: [objectId], references: [id], onDelete: Cascade)
  objectId Int?    @map("object_id")

  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId Int?         @map("transaction_id")

  task   Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId Int?  @map("task_id")

  taskHistory   TaskHistory? @relation(fields: [taskHistoryId], references: [id], onDelete: Cascade)
  taskHistoryId Int?

  inventory   Inventory? @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  inventoryId Int?       @map("inventory_id")

  inventoryHistory   InventoryHistory? @relation(fields: [inventoryHistoryId], references: [id], onDelete: Cascade)
  inventoryHistoryId Int?              @map("inventory_history_id")

  invoice               Entry? @relation("invoice_file", fields: [invoiceEntryId], references: [id], onDelete: Cascade)
  invoiceEntryId        Int?   @map("invoice_entry_id")
  bankAcceptence        Entry? @relation("bank_acceptance_file", fields: [bankAcceptanceEntryId], references: [id], onDelete: Cascade)
